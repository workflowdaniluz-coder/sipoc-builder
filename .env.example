# ─────────────────────────────────────────────────────────────
# SIPOC Builder — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────
# Copie este arquivo para .env.local (desenvolvimento local)
# NÃO commite arquivos .env.local ou .env.*.local no Git.
# As variáveis reais são configuradas na Vercel por ambiente.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Produção  → projeto Supabase real (xeqlaezylfoavmdztmws)
# Homologação → projeto Supabase separado criado para staging
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ── Monday.com ───────────────────────────────────────────────
# Gerar em: monday.com → perfil → Developer → My Access Tokens
# ATENÇÃO: nunca exponha com prefixo VITE_ — esta variável é server-side only
MONDAY_API_KEY=sua-api-key-aqui

# ── Notifications API ────────────────────────────────────────
# Chave que o agente externo usa para autenticar no POST /api/notifications
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ATENÇÃO: não prefixar com VITE_ — esta variável é server-side only
NOTIFICATIONS_API_KEY=gere-uma-chave-aqui

# Service role key do Supabase (server-side only, nunca expor no frontend)
# Obter em: Supabase Dashboard → Settings → API → service_role
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ── BPMN Validation (futuro) ─────────────────────────────────
# VITE_BPMN_VALIDATOR_URL=https://seu-validador.com/api
